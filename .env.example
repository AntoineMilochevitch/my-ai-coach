# =====================================================================
# Variables d'environnement my-ai-coach
# Copie ce fichier en .env (non versionné) et remplis les valeurs.
# =====================================================================

# --- Frontend (exposé au navigateur — OK, protégé par la RLS Supabase) ---
VITE_SUPABASE_URL=https://TON-PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=ta_cle_anon

# --- Netlify Functions (côté serveur UNIQUEMENT — jamais exposé au client) ---
# En PROD : à définir dans Netlify (Site settings > Environment variables).
# En LOCAL : `netlify dev` lit ce .env (gitignoré) — renseigne-les ici pour tester.
SUPABASE_URL=https://TON-PROJET.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ta_cle_service_role
# 32 octets base64 :  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=
# Clé API Gemini (https://aistudio.google.com/apikey) — analyse IA (Phase 3)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash   # optionnel

# --- Spike local Garmin uniquement (scripts/garmin-login-spike.ts) ---
# GARMIN_EMAIL=
# GARMIN_PASSWORD=
